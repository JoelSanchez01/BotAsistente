# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el .env real a GitHub (.gitignore ya lo excluye).

# Token del bot — obtenlo hablando con @BotFather en Telegram
TELEGRAM_TOKEN=123456789:AABBCCaabbcc...

# Tu ID de Telegram — escribe /start al bot @userinfobot para obtenerlo
ALLOWED_USER_ID=987654321

# Cadena de conexión a PostgreSQL (Supabase, Render Postgres, etc.)
# Formato: postgresql://usuario:contraseña@host:puerto/base_de_datos
DATABASE_URL=postgresql://postgres:contraseña@db.xxxx.supabase.co:5432/postgres

# Modo de ejecución: "dev" (polling local) o "prod" (webhook en servidor)
MODO=dev

# Solo necesario en modo prod si NO estás en Render
# (Render provee RENDER_EXTERNAL_URL automáticamente)
# WEBHOOK_URL=https://tu-dominio.com
